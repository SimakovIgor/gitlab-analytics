      "type": "timeseries",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 9 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
