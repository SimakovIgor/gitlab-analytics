          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT\n  date_trunc('day', started_at) AS time,\n  COUNT(*) FILTER (WHERE status = 'COMPLETED') AS \"Successful\",\n  COUNT(*) FILTER (WHERE status = 'FAILED') AS \"Failed\",\n  COUNT(*) FILTER (WHERE status = 'STARTED') AS \"In Progress\"\nFROM sync_job\nWHERE $__timeFilter(started_at)\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }

  ]
}
