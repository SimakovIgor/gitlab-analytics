    {
      "id": 31,
      "title": "New Workspaces per Day",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 9 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "none",
            "spanNulls": false,
            "showPoints": "auto",
            "pointSize": 5,
            "drawStyle": "bars"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT\n  date_trunc('day', created_at) AS time,\n  COUNT(*) AS \"New Workspaces\"\nFROM workspace\nWHERE $__timeFilter(created_at)\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },

