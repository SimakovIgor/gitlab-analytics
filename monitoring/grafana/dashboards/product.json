          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT\n  date_trunc('day', merged_at_gitlab) AS time,\n  COUNT(*) AS \"MRs Merged\"\nFROM merge_request\nWHERE merged_at_gitlab IS NOT NULL\n  AND $__timeFilter(merged_at_gitlab)\nGROUP BY 1\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },

    {
      "id": 34,
      "title": "Sync Jobs per Day",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 9 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
