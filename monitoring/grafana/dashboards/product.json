    {
      "id": 24,
      "title": "Sync Success Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 11, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgresql" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto",
        "wideLayout": true,
        "showPercentChange": false
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 95 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "postgresql" },
          "rawSql": "SELECT CASE WHEN COUNT(*) = 0 THEN NULL ELSE ROUND(100.0 * COUNT(*) FILTER (WHERE status = 'COMPLETED') / COUNT(*), 1) END AS value FROM sync_job",
          "format": "table",
          "refId": "A"
        }
      ]
    },

