{
  "title": "GitLab Analytics — Spring Boot",
  "uid": "gitlab-analytics-jvm",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_uptime_seconds{application=\"gitlab-analytics\"}",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "id": 2,
      "title": "CPU Usage",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.5 },
            { "color": "red", "value": 0.8 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage{application=\"gitlab-analytics\"}",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 3,
      "title": "JVM Heap Used",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 256000000 },
            { "color": "red", "value": 512000000 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{application=\"gitlab-analytics\", area=\"heap\"})",
          "legendFormat": "heap used"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP RPS",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"gitlab-analytics\"}[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 5,
      "title": "HikariCP Active Connections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 9 }
          ]}
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{application=\"gitlab-analytics\"}",
          "legendFormat": "active"
        }
      ]
    },
    {
      "id": 6,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (uri, method, status) (rate(http_server_requests_seconds_count{application=\"gitlab-analytics\", uri!~\"/actuator.*\"}[1m]))",
          "legendFormat": "{{method}} {{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{application=\"gitlab-analytics\", uri!~\"/actuator.*\"}[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"gitlab-analytics\", uri!~\"/actuator.*\"}[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"gitlab-analytics\", uri!~\"/actuator.*\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "title": "JVM Memory — Heap",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{application=\"gitlab-analytics\", area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_committed_bytes{application=\"gitlab-analytics\", area=\"heap\"})",
          "legendFormat": "committed"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_max_bytes{application=\"gitlab-analytics\", area=\"heap\"})",
          "legendFormat": "max"
        }
      ]
    },
    {
      "id": 9,
      "title": "JVM Memory — Non-Heap",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_used_bytes{application=\"gitlab-analytics\", area=\"nonheap\"})",
          "legendFormat": "used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(jvm_memory_committed_bytes{application=\"gitlab-analytics\", area=\"nonheap\"})",
          "legendFormat": "committed"
        }
      ]
    },
    {
      "id": 10,
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_cpu_usage{application=\"gitlab-analytics\"}",
          "legendFormat": "process cpu"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "system_cpu_usage{application=\"gitlab-analytics\"}",
          "legendFormat": "system cpu"
        }
      ]
    },
    {
      "id": 11,
      "title": "Process Memory",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "process_memory_virtual_bytes{application=\"gitlab-analytics\"}",
          "legendFormat": "virtual"
        }
      ]
    },
    {
      "id": 12,
      "title": "GC Pause Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_count{application=\"gitlab-analytics\"}[1m]))",
          "legendFormat": "{{action}} / {{cause}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{application=\"gitlab-analytics\"}[1m]))",
          "legendFormat": "{{action}} / {{cause}}"
        }
      ]
    },
    {
      "id": 14,
      "title": "JVM Threads",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_live_threads{application=\"gitlab-analytics\"}",
          "legendFormat": "live"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_daemon_threads{application=\"gitlab-analytics\"}",
          "legendFormat": "daemon"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_threads_peak_threads{application=\"gitlab-analytics\"}",
          "legendFormat": "peak"
        }
      ]
    },
    {
      "id": 15,
      "title": "HikariCP Connection Pool",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{application=\"gitlab-analytics\"}",
          "legendFormat": "active"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_idle{application=\"gitlab-analytics\"}",
          "legendFormat": "idle"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{application=\"gitlab-analytics\"}",
          "legendFormat": "pending"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections{application=\"gitlab-analytics\"}",
          "legendFormat": "total"
        }
      ]
    }
  ]
}
