    {
      "id": 7,
      "title": "HTTP \u2014 Incoming",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 8,
      "title": "RPS by Endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 8,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 3,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (method, uri) (rate(http_server_requests_seconds_count{application=\"gitlab-analytics\",uri!~\"/actuator.*|/swagger.*|/v3.*\"}[1m]))",
          "legendFormat": "{{method}} {{uri}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Latency \u2014 p50 / p95 / p99",
      "type": "timeseries",
