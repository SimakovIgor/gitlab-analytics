{
  "annotations": {
    "list": []
  },
  "description": "Per-container status, uptime, CPU and memory for all running Docker containers",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"fixedColor": "green", "mode": "fixed"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          },
          "unit": "none"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "title": "Running Containers",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "count(count by (name)(container_last_seen{image!=\"\"}))",
          "instant": true,
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 50},
              {"color": "red", "value": 80}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 0},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "title": "Total CPU Usage",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(rate(container_cpu_usage_seconds_total{image!=\"\"}[2m])) * 100",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1073741824},
              {"color": "red", "value": 2147483648}
            ]
          },
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 0},
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "title": "Total Memory Usage",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum(container_memory_working_set_bytes{image!=\"\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {
            "align": "left",
            "cellOptions": {"type": "auto"},
            "filterable": true,
            "inspect": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}]
          }
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Container"},
            "properties": [
              {"id": "custom.width", "value": 260},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Status"},
            "properties": [
              {"id": "custom.width", "value": 100},
              {"id": "mappings", "value": [
                {"options": {"from": 0, "to": 30, "result": {"color": "green", "index": 0, "text": "● Running"}}, "type": "range"},
                {"options": {"from": 30, "to": 999999999, "result": {"color": "red", "index": 1, "text": "● Stale"}}, "type": "range"}
              ]},
              {"id": "custom.cellOptions", "value": {"type": "color-text"}},
              {"id": "unit", "value": "none"}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Uptime"},
            "properties": [
              {"id": "unit", "value": "s"},
              {"id": "custom.width", "value": 130},
              {"id": "decimals", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "CPU %"},
            "properties": [
              {"id": "unit", "value": "percent"},
              {"id": "custom.width", "value": 110},
              {"id": "decimals", "value": 2},
              {"id": "custom.cellOptions", "value": {"mode": "lcd", "type": "gauge", "valueDisplayMode": "text"}},
              {"id": "color", "value": {"mode": "thresholds"}},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 30},
                  {"color": "red", "value": 70}
                ]
              }},
              {"id": "min", "value": 0},
              {"id": "max", "value": 100}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Memory"},
            "properties": [
              {"id": "unit", "value": "bytes"},
              {"id": "custom.width", "value": 120},
              {"id": "decimals", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Mem Limit"},
            "properties": [
              {"id": "unit", "value": "bytes"},
              {"id": "custom.width", "value": 120},
              {"id": "decimals", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Restarts"},
            "properties": [
              {"id": "unit", "value": "short"},
              {"id": "custom.width", "value": 90},
              {"id": "decimals", "value": 0},
              {"id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  {"color": "green", "value": null},
                  {"color": "yellow", "value": 1},
                  {"color": "red", "value": 5}
                ]
              }},
              {"id": "custom.cellOptions", "value": {"type": "color-background"}},
              {"id": "color", "value": {"mode": "thresholds"}}
            ]
          },
          {
            "matcher": {"id": "byName", "options": "Image"},
            "properties": [
              {"id": "custom.width", "value": 220}
            ]
          }
        ]
      },
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 4},
      "id": 4,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": false, "displayName": "Container"}]
      },
      "title": "Container Details",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "id": true,
              "instance": true,
              "job": true,
              "container_label_com_docker_compose_config_hash": true,
              "container_label_com_docker_compose_container_number": true,
              "container_label_com_docker_compose_depends_on": true,
              "container_label_com_docker_compose_image": true,
              "container_label_com_docker_compose_oneoff": true,
              "container_label_com_docker_compose_project": true,
              "container_label_com_docker_compose_project_config_files": true,
              "container_label_com_docker_compose_project_environment_file": true,
              "container_label_com_docker_compose_project_working_dir": true,
              "container_label_com_docker_compose_version": true,
              "container_label_desktop_docker_io_binds_0_source": true,
              "container_label_desktop_docker_io_binds_0_target": true,
              "container_label_desktop_docker_io_binds_1_source": true,
              "container_label_desktop_docker_io_binds_1_target": true,
              "container_label_desktop_docker_io_binds_2_source": true,
              "container_label_desktop_docker_io_binds_2_target": true,
              "container_label_maintainer": true
            },
            "indexByName": {},
            "renameByName": {
              "Value #A": "Status",
              "Value #B": "Uptime",
              "Value #C": "CPU %",
              "Value #D": "Memory",
              "Value #E": "Mem Limit",
              "Value #F": "Restarts",
              "name": "Container",
              "image": "Image",
              "container_label_com_docker_compose_service": "Service"
            }
          }
        }
      ],
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "time() - container_last_seen{image!=\"\"}",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by (name, image, container_label_com_docker_compose_service) (time() - container_start_time_seconds{image!=\"\"})",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{image!=\"\"}[2m])) * 100",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by (name) (container_memory_working_set_bytes{image!=\"\"})",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "D"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by (name) (container_spec_memory_limit_bytes{image!=\"\"} > 0)",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "E"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by (name) (container_oom_events_total{image!=\"\"})",
          "instant": true,
          "legendFormat": "{{name}}",
          "refId": "F"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 10,
      "title": "CPU per Container",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 17},
      "id": 5,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "CPU Usage per Container",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{image!=\"\"}[$__rate_interval])) * 100",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25},
      "id": 11,
      "title": "Memory per Container",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "bytes"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
      "id": 6,
      "options": {
        "legend": {"calcs": ["mean", "max", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "Memory Usage per Container (Working Set)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "max by (name) (container_memory_working_set_bytes{image!=\"\"})",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 34},
      "id": 12,
      "title": "Network I/O per Container",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 5,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 35},
      "id": 7,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "Network RX (Receive) per Container",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (name) (rate(container_network_receive_bytes_total{image!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 5,
            "gradientMode": "none",
            "hideFrom": {"legend": false, "tooltip": false, "viz": false},
            "insertNulls": false,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": {"type": "linear"},
            "showPoints": "never",
            "spanNulls": false,
            "stacking": {"group": "A", "mode": "none"},
            "thresholdsStyle": {"mode": "off"}
          },
          "mappings": [],
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 35},
      "id": 8,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "title": "Network TX (Transmit) per Container",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (name) (rate(container_network_transmit_bytes_total{image!=\"\"}[$__rate_interval]))",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docker", "containers"],
  "templating": {"list": []},
  "time": {"from": "now-30m", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Container Status",
  "uid": "container-status",
  "version": 1
}
