<?xml version="1.0"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD SuppressionFilter Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">
<suppressions>
    <!-- Test classes naturally couple many repositories/services and accumulate many test methods -->
    <suppress checks="ClassDataAbstractionCoupling" files=".*Test\.java"/>
    <suppress checks="MethodCount" files=".*Test\.java"/>
    <!-- Test methods use snake_case naming (given_when_then) for readability -->
    <suppress checks="MethodName" files=".*Test\.java"/>
</suppressions>
