# Server connection
SERVER_IP=176.124.216.43
SERVER_USER=root

# Database password (минимум 16 символов)
DB_PASSWORD=change-me-db-password

# Bearer token для REST API (/api/v1/**)
API_TOKEN=change-me-api-token

# Encryption (AES-256-GCM для токенов GitLab в БД)
# Включить в проде: APP_ENCRYPTION_ENABLED=true
# Ключ: 32 случайных байта в base64 → openssl rand -base64 32
APP_ENCRYPTION_ENABLED=true
APP_ENCRYPTION_KEY=change-me-run-openssl-rand-base64-32

# Public URL (используется в email-ссылках)
APP_BASE_URL=https://gitpulse.ru

# SMTP (Resend.com: host=smtp.resend.com, user=resend, pass=re_xxxxxxxxx)
# Без этих настроек email-верификация и сброс пароля работают в no-op режиме.
SPRING_MAIL_HOST=smtp.resend.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=resend
SPRING_MAIL_PASSWORD=change-me-resend-api-key
# От кого приходят письма (must be verified in Resend)
APP_MAIL_FROM=noreply@gitpulse.ru

# Jira (опционально — для DORA Change Failure Rate + MTTR)
# Если JIRA_BASE_URL пуст, Jira-интеграция отключена
JIRA_BASE_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=

# Grafana admin password
GRAFANA_PASSWORD=change-me-grafana-password
